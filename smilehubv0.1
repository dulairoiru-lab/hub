Tab:AddButton({
    Name = "🌪️ 家貫通Kick All (空中円形配置)",
    Callback = function()
        if isActive then return end
        isActive = true
        local blob = EnsureBlobman()
        local myRoot = LP.Character.HumanoidRootPart
        local originalPos = myRoot.CFrame
        
        local targets = {}
        for _, p in ipairs(Players:GetPlayers()) do
