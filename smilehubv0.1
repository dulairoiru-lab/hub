-[span_0](start_span)[span_1](start_span)[span_2](start_span)- 自分のブロブマンを探す[span_0](end_span)[span_1](end_span)[span_2](end_span)
local function findMyBlobman()
    local folder = workspace:FindFirstChild(LP.Name .. "SpawnedInToys")
    if folder then
        local b = folder:FindFirstChild("CreatureBlobman")
        if b and b:FindFirstChild("VehicleSeat") then return b end
    end
    return nil
end

-[span_3](start_span)[span_4](start_span)[span_5](start_span)[span_6](start_span)- ブロブマンの準備（スポーン & 搭乗）[span_3](end_span)[span_4](end_span)[span_5](end_span)[span_6](end_span)
local function EnsureBlobman()
    local blob = findMyBlobman()
    if not blob then
        RS.MenuToys.SpawnToyRemoteFunction:InvokeServer("CreatureBlobman", LP.Character.HumanoidRootPart.CFrame, Vector3.new(0, 127, 0))
        task.wait(0.8)
        blob = findMyBlobman()
    end
    
    if blob then
        local seat = blob.VehicleSeat
        local hum = LP.Character:FindFirstChildOfClass("Humanoid")
        if hum and not hum.Sit then
            seat:Sit(hum)
            task.wait(0.3)
        end
    end
    return blob
end

-[span_7](start_span)[span_8](start_span)[span_9](start_span)[span_10](start_span)- 6秒キック / 掴み・離しロジック[span_7](end_span)[span_8](end_span)[span_9](end_span)[span_10](end_span)
local function ExecuteGrabProcess(blob, targetRoot, mode)
    local script = blob:FindFirstChild("BlobmanSeatAndOwnerScript", true)
    local remoteGrab = script:FindFirstChild("CreatureGrab")
    local remoteDrop = script:FindFirstChild("CreatureDrop") or script:FindFirstChild("CreatureRelease")
    local det = blob:FindFirstChild("LeftDetector")
    local weld = det and (det:FindFirstChild("LeftWeld") or det:FindFirstChildWhichIsA("Weld"))

    pcall(function()
        -[span_11](start_span)[span_12](start_span)[span_13](start_span)- ネットワークオーナー取得[span_11](end_span)[span_12](end_span)[span_13](end_span)
        RS.GrabEvents.SetNetworkOwner:FireServer(targetRoot, LP.Character.HumanoidRootPart.CFrame)
        task.wait(0.08)
        
        if mode == "Kick" then
            [span_14](start_span)targetRoot.CFrame = targetRoot.CFrame + Vector3.new(0, 16, 0) -- 浮かせる[span_14](end_span)
            task.wait(0.08)
            remoteGrab:FireServer(det, targetRoot, weld)
            task.wait(0.08)
            [span_15](start_span)remoteDrop:FireServer(det, targetRoot) -- 排除[span_15](end_span)
            RS.GrabEvents.DestroyGrabLine:FireServer(targetRoot)
        elseif mode == "Grab" then
            remoteGrab:FireServer(det, targetRoot, weld)
        elseif mode == "Release" then
            remoteDrop:FireServer(det, targetRoot)
        end
    end)
end

